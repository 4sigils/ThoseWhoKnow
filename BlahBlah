-- finds the Muhammad Avdol NPC
local function findAvdolNPC()
    for _, obj in liveFolder:GetChildren() do
        if obj.Name == "Server" then continue end
        if not obj:IsA("Model") then continue end
        if playerNames[obj.Name] then continue end
        if obj.Name:sub(1, 15) ~= ".Muhammad Avdol" then continue end
        if not obj:FindFirstChild("HumanoidRootPart") then continue end
        local hum = obj:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        return obj
    end
    return nil
end

-- Anubis fight loop inside the raid place
local function startAnubisRaidFight(state)
    local SAFE_POS = Vector3.new(786, 1016, -8)
    local skillKeys = {R_KEY, Z_KEY2, X_KEY2, C_KEY}

    -- click Quick Play if the main menu is open
    -- click Quick Play if Main Menu is present
    local playerGui = player:WaitForChild("PlayerGui")
    local mainMenu = playerGui:FindFirstChild("Main Menu")
    if mainMenu then
        print("[Avdol Raid] Found Main Menu, waiting for Quick Play button...")
        local buttons = mainMenu:WaitForChild("Buttons", 5)
        local quickPlay = buttons and buttons:WaitForChild("Quick Play", 5)
        if quickPlay then
            print("[Avdol Raid] Clicking Quick Play...")
            task.wait(0.5)
            pcall(function()
                local abs = quickPlay.AbsolutePosition
                local sz = quickPlay.AbsoluteSize
                local startX = abs.X + sz.X / 2 + 50
                local y = abs.Y + sz.Y / 2
                -- move to button position first
                mousemoveabs(startX, y)
                task.wait(0.2)
                -- smoothly slide 25px to the right
                for i = 1, 25 do
                    mousemoveabs(startX + i, y)
                    task.wait(0.01)
                end
                task.wait(0.1)
                mouse1press()
                task.wait(0.1)
                mouse1release()
            end)
            task.wait(3)
        end
    end

    -- teleport to safe spot first
    local hrp = getHRP()
    if hrp then
        pcall(function()
            hrp.Position = SAFE_POS
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end)
    end
    task.wait(0.5)

    -- summon stand if not already summoned
    pressTabUntilStandSummoned()

    while state.alive do
        local hasSelection = false
        for _ in pairs(avdolOptions) do hasSelection = true break end
        if not hasSelection then
            print("[Avdol Raid] No option selected in dropdown, please select one.")
            task.wait(2)
            continue
        end

        -- find Avdol NPC
        local avdol = findAvdolNPC()
        if not avdol then
            -- NPC not found, wait at safe spot
            hrp = getHRP()
            if hrp then
                pcall(function()
                    hrp.Position = SAFE_POS
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end)
            end
            task.wait(1)
            continue
        end

        local avdolHRP = avdol:FindFirstChild("HumanoidRootPart")
        if not avdolHRP then task.wait(0.5) continue end

        -- teleport to Avdol's position
        hrp = getHRP()
        if hrp then
            pcall(function()
                hrp.Position = avdolHRP.Position
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            end)
        end

        -- cycle through skill keys: R, Z, X, C
        for _, key in ipairs(skillKeys) do
            if not state.alive then break end

            -- press skill
            pcall(keypress, key)
            task.wait(0.1)
            pcall(keyrelease, key)

            -- wait 0.25s then teleport to Avdol
            task.wait(0.25)
            avdol = findAvdolNPC()
            avdolHRP = avdol and avdol:FindFirstChild("HumanoidRootPart")
            if avdolHRP then
                hrp = getHRP()
                if hrp then
                    pcall(function()
                        hrp.Position = avdolHRP.Position
                        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end)
                end
            end

            -- wait 1 second then go back to safe spot
            task.wait(1)
            hrp = getHRP()
            if hrp then
                pcall(function()
                    hrp.Position = SAFE_POS
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end)
            end
            -- stay at safe spot for 1-2 seconds before next skill
            task.wait(1.5)
        end

        -- wait 10 seconds before replaying the skill cycle
        task.wait(10)
    end
end

