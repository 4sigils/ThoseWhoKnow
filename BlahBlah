-- ── Fixed AddDropdown (floating + scrollable) ────────────────────────────────
local oldAddDropdown -- you'll set this after defining the method

local function patchedDropdown(section, label, options, default, cfg, callback)
    cfg = cfg or {}
    local maxVisible = cfg.MaxVisible or 8

    -- Let original create the base widget/button
    local widget = oldAddDropdown(section, label, options, default, cfg, callback)

    -- Assume widget has .Button (TextButton) and .List (Frame/ScrollingFrame)
    local btn = widget.Button or widget:FindFirstChildWhichIsA("TextButton")
    local list = widget.List or widget:FindFirstChild("List") or widget:FindFirstChildWhichIsA("ScrollingFrame")

    if not btn or not list then
        warn("[Fixed Dropdown] Structure not found for: " .. label)
        return widget
    end

    -- Detach list → make floating
    list.Parent = section.Window.Overlay  -- or window.Screen
    list.ZIndex = 1000
    list.Visible = false
    list.ClipsDescendants = true
    list.BorderSizePixel = 1
    list.BorderColor3 = T.Border0

    -- Scroll wheel support
    list.MouseWheelForward:Connect(function()
        if list.Visible then
            list.CanvasPosition = list.CanvasPosition - Vector2.new(0, 25)
        end
    end)
    list.MouseWheelBackward:Connect(function()
        if list.Visible then
            list.CanvasPosition = list.CanvasPosition + Vector2.new(0, 25)
        end
    end)

    -- Position list below button when opened
    local conn = game:GetService("RunService").RenderStepped:Connect(function()
        if list.Visible and btn.AbsolutePosition then
            list.Position = UDim2.fromOffset(btn.AbsolutePosition.X, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y + 2)
            list.Size = UDim2.fromOffset(btn.AbsoluteSize.X, math.min(#options * 28, maxVisible * 28))
        end
    end)

    -- Toggle open/close
    local oldClick = btn.MouseButton1Click
    btn.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        section.Window.Overlay.Visible = list.Visible
    end)

    -- Close on outside click
    local uis = game:GetService("UserInputService")
    uis.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and list.Visible then
            local mp = uis:GetMouseLocation()
            local overList = over(Vector2.new(list.AbsolutePosition.X, list.AbsolutePosition.Y), Vector2.new(list.AbsoluteSize.X, list.AbsoluteSize.Y))
            local overBtn = over(Vector2.new(btn.AbsolutePosition.X, btn.AbsolutePosition.Y), Vector2.new(btn.AbsoluteSize.X, btn.AbsoluteSize.Y))
            if not overList and not overBtn then
                list.Visible = false
                section.Window.Overlay.Visible = false
            end
        end
    end)

    -- Return same widget interface
    return widget
end

