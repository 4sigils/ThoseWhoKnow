-- Auto PvE
-- ─────────────────────────────────────────────
local PVE_QUEUE_POS = Vector3.new(2632.87, 874.66, -232.64)
local PVE_E_KEY     = 0x45
local PVE_CLICK_DT  = 1 / 30

local function getPveTargets()
    local t = {}
    for _, obj in liveFolder:GetChildren() do
        if obj.Name == "Server" then continue end
        if not obj:IsA("Model") then continue end
        if playerNames[obj.Name] then continue end
        if not obj:FindFirstChildWhichIsA("Highlight", true) then continue end
        if not obj:FindFirstChild("HumanoidRootPart") then continue end
        local hum = obj:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        table.insert(t, obj)
    end
    return t
end

local function startPvE(state)
    loadPveOffsets()

    local holderFrame = player.PlayerGui:WaitForChild("Notifications"):WaitForChild("holder")

    local QUEUE_PREFIX  = "Joined PvE Mission Queue"
    local EXTERM_PREFIX = "Exterminate the targets"

    while state.alive do

        -- ── 1. Queue up ───────────────────────────────────────
        print("[PvE] Queueing...")
        local queued = false
        while state.alive and not queued do
            local hrp = getHRP()
            if hrp then
                pcall(function()
                    hrp.Position = PVE_QUEUE_POS
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end)
            end
            task.wait(1)
            pcall(keypress, PVE_E_KEY); task.wait(1); pcall(keyrelease, PVE_E_KEY)
            queued = waitForHolderPrefix(holderFrame, QUEUE_PREFIX, 2)
            if not queued then print("[PvE] Not queued yet, retrying...") end
        end
        if not state.alive then break end
        print("[PvE] Queued! Detecting mission type...")

        -- ── 2. Detect mission type — questbrick spawns first, NPCs spawn after ─────────
        -- Check for questbrick first (spawns immediately). If none found after a
        -- short window, assume exterminate and wait for highlighted NPCs to appear.
        print("[PvE] Detecting mission type...")
        local isExterminate = nil
        local scanTimeout = 8
        local scanElapsed = 0

        -- First pass: look for a questbrick within 8 seconds
        while state.alive and scanElapsed < scanTimeout do
            local foundQB = false
            pcall(function()
                for _, qb in ipairs(Workspace.Effects:GetChildren()) do
                    local isKira = false
                    pcall(function()
                        local title = qb["Quest Marker"].Image.Title
                        if title and title.Text and title.Text:find("Yoshikage Kira") then
                            isKira = true
                        end
                    end)
                    if not isKira then
                        local pos = nil
                        pcall(function() pos = qb.questbrick.Position end)
                        if pos then foundQB = true end
                    end
                end
            end)
            if foundQB then
                isExterminate = false
                print("[PvE] Questbrick found — quest mission.")
                break
            end
            task.wait(0.5)
            scanElapsed = scanElapsed + 0.5
        end

        -- No questbrick found — must be exterminate
        if isExterminate == nil then
            isExterminate = true
            print("[PvE] No questbrick found — exterminate mission.")
        end

        -- ── 3a. Exterminate branch ────────────────────────────
        if isExterminate == true then
            print("[PvE] Exterminate mission!")

            -- Summon stand if not already summoned
            local standE = getSummonedStand()
            if not standE or standE == "" then
                pcall(keypress, TAB_KEY); task.wait(0.1); pcall(keyrelease, TAB_KEY)
                pressTabUntilStandSummoned()
            end

            -- Start aim-down only while fighting highlighted NPCs
            local aimActive = { alive = true }
            task.spawn(function()
                while aimActive.alive and state.alive do
                    applyAimDown()
                    task.wait(1/150)
                end
            end)

            -- Spam 1 and 2 keys while fighting
            local ONE_PVE = 0x31
            local TWO_PVE = 0x32
            local spamActive = { alive = true }
            task.spawn(function()
                while spamActive.alive and state.alive do
                    pcall(keypress, ONE_PVE); task.wait(0.05); pcall(keyrelease, ONE_PVE); task.wait(0.05)
                    pcall(keypress, TWO_PVE); task.wait(0.05); pcall(keyrelease, TWO_PVE); task.wait(0.05)
                end
            end)

            while state.alive do
                local targets = getPveTargets()

                -- Double-check targets are truly gone before requeuing
                if #targets == 0 then
                    task.wait(2)
                    targets = getPveTargets()
                    if #targets == 0 then
                        print("[PvE] All targets cleared — requeuing.")
                        break
                    end
                end

                local target = targets[math.random(1, #targets)]
                local npcHRP = target:FindFirstChild("HumanoidRootPart")
                local hum    = target:FindFirstChildWhichIsA("Humanoid")
                if not npcHRP or not hum then task.wait(0.1); continue end

                local hrp = getHRP()
                if hrp then
                    pcall(function()
                        hrp.Position = npcHRP.Position + Vector3.new(0, 5, 0)
                        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end)
                end
                task.wait(0.05)

                while state.alive do
                    hum    = target:FindFirstChildWhichIsA("Humanoid")
                    npcHRP = target:FindFirstChild("HumanoidRootPart")
                    if not hum or hum.Health <= 0 then
                        print("[PvE] Killed: " .. target.Name); break
                    end
                    hrp = getHRP()
                    if hrp and npcHRP then
                        pcall(function()
                            hrp.Position = npcHRP.Position + Vector3.new(0, 5, 0)
                            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        end)
                    end
                    pcall(mouse1press);  task.wait(PVE_CLICK_DT)
                    pcall(mouse1release); task.wait(PVE_CLICK_DT)
                end
            end

            -- Stop aim-down and key spam once all targets are cleared
            aimActive.alive = false
            spamActive.alive = false

        -- ── 3b. Questbrick branch ─────────────────────────────
        elseif isExterminate == false then
            print("[PvE] Quest mission! Looking for questbrick...")

            -- Unsummon stand if active
            local standQ = getSummonedStand()
            if standQ and standQ ~= "" then
                pcall(keypress, TAB_KEY); task.wait(0.1); pcall(keyrelease, TAB_KEY); task.wait(0.3)
            end

            local cycleComplete = false
            while state.alive and not cycleComplete do
                -- Find a non-Kira questbrick from the Effects folder
                local qbTarget = nil
                local qbPos = nil
                pcall(function()
                    for _, qb in ipairs(Workspace.Effects:GetChildren()) do
                        local isKira = false
                        pcall(function()
                            local title = qb["Quest Marker"].Image.Title
                            if title and title.Text and title.Text:find("Yoshikage Kira") then
                                isKira = true
                            end
                        end)
                        if not isKira then
                            local pos = nil
                            pcall(function() pos = qb.questbrick.Position end)
                            if pos then
                                qbTarget = qb
                                qbPos = pos
                                break
                            end
                        end
                    end
                end)

                if not qbPos then
                    print("[PvE] No valid questbrick found, retrying in 1s..."); task.wait(1); continue
                end

                print("[PvE] Found questbrick, teleporting...")

                -- Teleport to questbrick and hold E for 2 seconds
                local hrp = getHRP()
                if hrp then
                    pcall(function()
                        hrp.Position = qbPos
                        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end)
                end
                task.wait(0.3)
                pcall(keypress, PVE_E_KEY)
                task.wait(2)
                pcall(keyrelease, PVE_E_KEY)
                task.wait(1)

                -- Check if that specific questbrick is gone
                local stillExists = false
                pcall(function()
                    local _ = qbTarget.questbrick.Position
                    stillExists = true
                end)

                if not stillExists then
                    print("[PvE] Questbrick gone — cycle complete.")
                    cycleComplete = true
                else
                    print("[PvE] Questbrick still present, retrying in 3s...")
                    task.wait(3)
                end
            end
        end

        task.wait(1)
    end
end

