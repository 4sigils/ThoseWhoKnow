local function findPvPEnemy()
    local name = player.Name
    local candidates
    if name == "sigiltatted" then
        candidates = {"kyze_jay", "xen_yv"}
    elseif name == "kyze_jay" then
        candidates = {"sigiltatted", "xen_yv"}
    else
        candidates = {"sigiltatted", "kyze_jay"}
    end
    for _, n in ipairs(candidates) do
        local p = game.Players:FindFirstChild(n)
        if p and p.Character and p.Character.PrimaryPart then return p end
    end
    return nil
end

local function startPvP(state)
    local seen = {}

    local function waitForNew(prefix)
        while state.alive do
            for _, child in ipairs(holder:GetChildren()) do
                if not seen[child] and child:IsA("Frame") and child.Name:sub(1, #prefix) == prefix then
                    seen[child] = true
                    return child
                end
            end
            task.wait()
        end
        return nil
    end

    while state.alive do
        local hrp = getHRP()
        if not hrp then task.wait(0.2); continue end

        local queuePrefix = "Joined PvP Mission Queue"
        local queued = false
        while state.alive and not queued do
            hrp = getHRP()
            if hrp then pcall(function() hrp.Position = PVP_QUEUE_POS; hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end) end
            pcall(keypress, E_PVP_KEY); task.wait(1); pcall(keyrelease, E_PVP_KEY)
            for _, child in ipairs(holder:GetChildren()) do
                if seen[child] then continue end
                if child:IsA("Frame") and child.Name:sub(1, #queuePrefix) == queuePrefix then
                    seen[child] = true; queued = true; break
                end
            end
            if not queued then task.wait(2) end
        end
        if not state.alive then break end
        print("[PvP] Joined queue - waiting for opponent")

        local opponentPrefix = "Your opponent is"
        local opponentFrame  = waitForNew(opponentPrefix)
        if not opponentFrame then break end
        print("[PvP] Opponent found: " .. opponentFrame.Name)

        local character = player.Character
        if not character then task.wait(0.2); continue end

        if WINMODE then
            pcall(keypress, THREE_KEY); task.wait(0.1); pcall(keyrelease, THREE_KEY); task.wait(0.1)
            local enemy = findPvPEnemy()
            hrp = getHRP()
            if hrp and enemy then
                pcall(function() hrp.Position = enemy.Character.PrimaryPart.Position; hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end)
                print("[PvP] Teleported to enemy: " .. enemy.Name)
            end
            task.wait(10)
        else
            print("[PvP] Give mode - void every 3s until death")
            while state.alive do
                local hum = character:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then break end
                hrp = getHRP()
                if hrp then pcall(function() hrp.Position = PVP_LOSE_POS; hrp.AssemblyLinearVelocity = Vector3.new(0,0,0) end) end
                task.wait(3)
            end
            print("[PvP] Death detected - requeuing in 5s"); task.wait(5)
        end
    end
end

