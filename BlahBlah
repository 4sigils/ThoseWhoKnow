-- ─────────────────────────────────────────────
-- Aim-Down (memory write, 120 deg pitch)
-- ─────────────────────────────────────────────
local pve_primitive    = 0x148
local pve_cframepath   = 0xC0
local pveOffsetsLoaded = false

local function loadPveOffsets()
    if pveOffsetsLoaded then return end
    pveOffsetsLoaded = true
    pcall(function()
        local raw = game:HttpGet("https://offsets.ntgetwritewatch.workers.dev/offsets.hpp")
        for name, hex in raw:gmatch("inline constexpr uintptr_t ([%w_]+)%s*=%s*(0x%x+);") do
            if name == "CFrame" then
                pve_cframepath = tonumber(hex)
                print("[PvE] CFrame offset:", string.format("0x%X", pve_cframepath))
            end
        end
    end)
end

local function pveGetPrimitive(part)
    return memory_read("uintptr_t", part.Address + pve_primitive)
end

local function pveWriteDown(part)
    local addr = pveGetPrimitive(part)
    if not addr or addr == 0 then return end
    local r = math.rad(120); local c, s = math.cos(r), math.sin(r)
    memory_write("float", addr + pve_cframepath + 0x00, 1)
    memory_write("float", addr + pve_cframepath + 0x04, 0)
    memory_write("float", addr + pve_cframepath + 0x08, 0)
    memory_write("float", addr + pve_cframepath + 0x0C, 0)
    memory_write("float", addr + pve_cframepath + 0x10, c)
    memory_write("float", addr + pve_cframepath + 0x14, s)
    memory_write("float", addr + pve_cframepath + 0x18, 0)
    memory_write("float", addr + pve_cframepath + 0x1C, -s)
    memory_write("float", addr + pve_cframepath + 0x20, c)
end

local function applyAimDown()
    local char = player.Character
    if not char then return end
    local root  = char:FindFirstChild("HumanoidRootPart")
    local upper = char:FindFirstChild("UpperTorso")
    local torso = char:FindFirstChild("Torso")
    if root  then pcall(pveWriteDown, root)  end
    if upper then pcall(pveWriteDown, upper) end
    if torso then pcall(pveWriteDown, torso) end
end

