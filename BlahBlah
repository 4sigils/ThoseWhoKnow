local ALLOWED_PLACE_ID = 14890802310

local function isCorrectGame()
    return game.PlaceId == ALLOWED_PLACE_ID
end

-- 1. Anubis AutoFarm  (Prison Escapee — prefix match, keys R + X)
local function startAnubis(state)
    if not isCorrectGame() then
        warn("[Anubis] Wrong game. PlaceId must be " .. ALLOWED_PLACE_ID)
        return
    end
    local SPAWN_POS = Vector3.new(840, 886, -625)
    local R_KEY = 0x52
    local X_KEY = 0x58

    local waitForNPC, pickNPC = makeNPCLoop(function(obj)
        return obj.Name:sub(1, 15) == ".Prison Escapee"
    end, SPAWN_POS)

    -- Spam R
    task.spawn(function()
        while state.alive do
            pcall(keypress, R_KEY);  task.wait(0.1)
            pcall(keyrelease, R_KEY); task.wait(0.1)
        end
    end)

    -- Spam X (15-second cooldown)
    task.spawn(function()
        while state.alive do
            pcall(keypress, X_KEY);  task.wait(0.1)
            pcall(keyrelease, X_KEY); task.wait(15)
        end
    end)

    runMovementLoop(state, waitForNPC, pickNPC, SPAWN_POS)
end

-- 2. Bizarre Lineage Auto Escapee  (Prison Escapee — find match, key R)
local function startBizarre(state)
    if not isCorrectGame() then
        warn("[Bizarre] Wrong game. PlaceId must be " .. ALLOWED_PLACE_ID)
