local function holderHasPrefix(h, prefix)
    for _, child in ipairs(h:GetChildren()) do
        if child:IsA("Frame") and child.Name:sub(1, #prefix) == prefix then return true end
    end
    return false
end

local function waitForHolderPrefix(h, prefix, timeout)
    local elapsed, step = 0, 1/60
    while not timeout or elapsed < timeout do
        for _, child in ipairs(h:GetChildren()) do
            if child:IsA("Frame") and child.Name:sub(1, #prefix) == prefix then
                return true
            end
        end
        task.wait(step)
        elapsed = elapsed + step
    end
    return false
end

