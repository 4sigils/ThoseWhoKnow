local function autoRetryFarm(state)
    while state.alive do
        pcall(function()
            local playerGui = player:FindFirstChild("PlayerGui")
            if not playerGui then return end
            local raidComplete = playerGui:FindFirstChild("raidcomplete")
            if not raidComplete then return end
            print("[AutoRetry] raidcomplete detected, clicking retry...")
            local retryBtn = raidComplete.raid.retry.TextButton
            local rabs = retryBtn.AbsolutePosition
            local rsz = retryBtn.AbsoluteSize
            local startX = rabs.X + rsz.X / 2
            local posY = rabs.Y + rsz.Y / 2
            mousemoveabs(startX, posY)
            task.wait(0.2)
            for i = 1, 25 do
                mousemoveabs(startX + i, posY)
                task.wait(0.01)
            end
            task.wait(0.1)
            mouse1press()
            task.wait(0.1)
            mouse1release()
            task.wait(1)
        end)
        task.wait(0.5)
    end
end

