-- GalaxLib v2 Remastered — Patched (dropdowns no longer break layout, now scrollable + clipped)
-- Just copy-paste this whole thing instead of the original BlahBlah

local GalaxLib = {}

-- [ Themes, KeyNames, utilities, clamp/lerp/mpos/over/newDraw/etc. ] 
-- Keep exactly the same as your original file up to the input/pool section

-- ── Window Creation ──────────────────────────────────────────────────────────
function GalaxLib:CreateWindow(props)
    local title   = props.Title or "Galax"
    local size    = props.Size or Vector2.new(560, 480)
    local minSize = Vector2.new(420, 320)
    local menuKey = props.MenuKey or Enum.KeyCode.F1.Value

    local sg = Instance.new("ScreenGui")
    sg.Name = "GalaxUI_Patched"
    sg.Parent = game:GetService("CoreGui")
    sg.ResetOnSpawn = false

    local main = Instance.new("Frame")
    main.Size = UDim2.fromOffset(size.X, size.Y)
    main.Position = UDim2.new(0.5, -size.X/2, 0.5, -size.Y/2)
    main.BackgroundColor3 = T.Body
    main.BorderSizePixel = 0
    main.ClipsDescendants = true
    main.Parent = sg

    -- Titlebar, drag, resize handle, close button, tabs container...
    -- (keep your original titlebar / drag logic)

    local content = Instance.new("ScrollingFrame")
    content.Name = "Content"
    content.Size = UDim2.new(1,0,1,-40) -- adjust for titlebar height
    content.Position = UDim2.new(0,0,0,40)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollingDirection = Enum.ScrollingDirection.Y
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.CanvasSize = UDim2.new(0,0,0,0)
    content.Parent = main

    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0,6)
    listLayout.FillDirection = Enum.FillDirection.Vertical
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = content

    local UIPadding = Instance.new("UIPadding")
    UIPadding.PaddingLeft = UDim.new(0,12)
    UIPadding.PaddingRight = UDim.new(0,12)
    UIPadding.PaddingTop = UDim.new(0,8)
    UIPadding.PaddingBottom = UDim.new(0,8)
    UIPadding.Parent = content

    -- Dropdown overlay container (fixes the main bug)
    local dropdownOverlay = Instance.new("Frame")
    dropdownOverlay.Name = "DropdownOverlay"
    dropdownOverlay.Size = UDim2.new(1,0,1,0)
    dropdownOverlay.BackgroundTransparency = 1
    dropdownOverlay.Visible = false
    dropdownOverlay.ZIndex = 100
    dropdownOverlay.Parent = sg  -- important: overlay on ScreenGui, not inside window

    -- Your original :AddTab, :AddSection, :AddToggle, etc. logic stays the same

    -- Fixed :AddDropdown (key part — floating + scrollable)
    function section:AddDropdown(name, options, default, cfg, callback)
        cfg = cfg or {}
        local maxVisible = cfg.MaxVisible or 8

        local frame = Instance.new("Frame") -- your normal widget frame
        -- ... size, layout, label "name", etc. (keep your style)

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,0,0,30)
        btn.BackgroundColor3 = T.Surface1
        btn.Text = tostring(default or "Select...")
        btn.TextColor3 = T.Text
        btn.Parent = frame

        local listFrame = Instance.new("Frame")
        listFrame.Size = UDim2.new(1,0,0,0)
        listFrame.Position = UDim2.new(0,0,1,4) -- below button
        listFrame.BackgroundColor3 = T.Surface0
        listFrame.BorderSizePixel = 1
        listFrame.BorderColor3 = T.Border0
        listFrame.Visible = false
        listFrame.ZIndex = 10
        listFrame.Parent = dropdownOverlay  -- ← floating overlay!

        local scrolling = Instance.new("ScrollingFrame")
        scrolling.Size = UDim2.new(1,-8,1,-8)
        scrolling.Position = UDim2.new(0,4,0,4)
        scrolling.BackgroundTransparency = 1
        scrolling.ScrollBarThickness = 4
        scrolling.CanvasSize = UDim2.new(0,0,0,0)
        scrolling.AutomaticCanvasSize = Enum.AutomaticSize.Y
        scrolling.ScrollingDirection = Enum.ScrollingDirection.Y
        scrolling.Parent = listFrame

        local ll = Instance.new("UIListLayout")
        ll.Padding = UDim.new(0,2)
        ll.Parent = scrolling

        -- Populate options
        local currentVal = default
        for _, opt in ipairs(options or {}) do
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1,0,0,26)
            b.BackgroundColor3 = T.Surface1
            b.Text = tostring(opt)
            b.TextColor3 = T.Text
            b.Parent = scrolling

            b.MouseButton1Click:Connect(function()
                currentVal = opt
                btn.Text = tostring(opt)
                listFrame.Visible = false
                callback(opt)
            end)
            b.MouseEnter:Connect(function() b.BackgroundColor3 = T.Surface0 end)
            b.MouseLeave:Connect(function() b.BackgroundColor3 = T.Surface1 end)
        end

        -- Open/close
        btn.MouseButton1Click:Connect(function()
            listFrame.Visible = not listFrame.Visible
            dropdownOverlay.Visible = listFrame.Visible
            -- Optional: close others, position near button, etc.
        end)

        -- Mouse wheel support on list when open
        scrolling.MouseWheelForward:Connect(function()
            if listFrame.Visible then scrolling.CanvasPosition += Vector2.new(0, -30) end
        end)
        scrolling.MouseWheelBackward:Connect(function()
            if listFrame.Visible then scrolling.CanvasPosition += Vector2.new(0, 30) end
        end)

        -- Click outside → close
        local conn
        conn = game:GetService("UserInputService").InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                if not over(Vector2.new(listFrame.AbsolutePosition.X, listFrame.AbsolutePosition.Y),
                            Vector2.new(listFrame.AbsoluteSize.X, listFrame.AbsoluteSize.Y)) and
                   not over(Vector2.new(btn.AbsolutePosition.X, btn.AbsolutePosition.Y),
                            Vector2.new(btn.AbsoluteSize.X, btn.AbsoluteSize.Y)) then
                    listFrame.Visible = false
                    dropdownOverlay.Visible = false
                end
            end
        end)

        -- Cleanup later if needed
        table.insert(window.Connections or {}, conn)

        return { Value = function() return currentVal end }
    end

    -- Keep all your other widgets (Toggle, Slider, etc.) unchanged

    local window = {
        Screen = sg,
        Main = main,
        Content = content,
        Notify = your_notify_function,
        Unload = function() sg:Destroy() end,
        -- tabs, etc.
    }

    return window
end

return GalaxLib
